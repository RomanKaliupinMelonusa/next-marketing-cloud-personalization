<% 
const body = `
<div class="row">
    <div class="col-lg-8 mx-auto">
        <h1 class="display-5 fw-bold text-primary mb-4">
            📞 Contact Us
        </h1>
        
        ${typeof success !== 'undefined' ? `
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> ${success}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        ` : ''}

        <div class="row">
            <div class="col-md-8">
                <h3>Send us a message</h3>
                <form method="POST" action="/contact" class="mt-4">
                    <div class="mb-3">
                        <label for="name" class="form-label">Full Name *</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address *</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="message" class="form-label">Message *</label>
                        <textarea class="form-control" id="message" name="message" rows="5" required placeholder="Tell us about your marketing cloud personalization needs..."></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary btn-lg">
                        📤 Send Message
                    </button>
                </form>
            </div>
            
            <div class="col-md-4">
                <h3>Get in Touch</h3>
                <div class="mt-4">
                    <div class="mb-3">
                        <h5>📧 Email</h5>
                        <p>info@marketingcloud.com</p>
                    </div>
                    
                    <div class="mb-3">
                        <h5>📱 Phone</h5>
                        <p>+1 (555) 123-4567</p>
                    </div>
                    
                    <div class="mb-3">
                        <h5>🏢 Address</h5>
                        <p>123 Marketing Street<br>
                        Digital City, DC 12345<br>
                        United States</p>
                    </div>
                    
                    <div class="mb-3">
                        <h5>🕒 Business Hours</h5>
                        <p>Monday - Friday: 9:00 AM - 6:00 PM<br>
                        Saturday: 10:00 AM - 2:00 PM<br>
                        Sunday: Closed</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <h3>🌐 Cross-Origin Request Testing</h3>
            <div class="alert alert-info">
                <p><strong>CORS Testing:</strong> This form can accept requests from any origin due to our permissive CORS policy.</p>
                <p><strong>External Resources:</strong> The page loads Bootstrap CSS/JS from CDN, demonstrating CSP allows external resources.</p>
            </div>
            
            <div class="mt-3">
                <button id="test-cors-btn" class="btn btn-outline-info">
                    🧪 Test External API Request
                </button>
                <div id="cors-test-result" class="mt-2"></div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a href="/" class="btn btn-primary me-3">← Back to Home</a>
            <a href="/about" class="btn btn-outline-primary">Learn More →</a>
        </div>
    </div>
</div>

<script>
    // Inline JavaScript demonstrating permissive CSP
    function testCorsRequest() {
        const resultDiv = document.getElementById('cors-test-result');
        resultDiv.innerHTML = '<div class="spinner-border spinner-border-sm text-info" role="status"></div> Testing CORS...';
        
        // This request will work due to permissive CORS configuration
        fetch('https://api.github.com/zen')
            .then(response => response.text())
            .then(data => {
                resultDiv.innerHTML = \`
                    <div class="alert alert-success mt-2">
                        <strong>✅ CORS Test Successful!</strong><br>
                        GitHub API Response: "\${data}"
                    </div>
                \`;
            })
            .catch(error => {
                resultDiv.innerHTML = \`
                    <div class="alert alert-danger mt-2">
                        <strong>❌ CORS Test Failed:</strong> \${error.message}
                    </div>
                \`;
            });
    }

    // Form validation with inline JavaScript (allowed by CSP)
    document.addEventListener('DOMContentLoaded', function() {
        // Add event listener for CORS test button
        const testButton = document.getElementById('test-cors-btn');
        if (testButton) {
            testButton.addEventListener('click', testCorsRequest);
        }
        
        const form = document.querySelector('form');
        form.addEventListener('submit', function(e) {
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const message = document.getElementById('message').value.trim();
            
            if (!name || !email || !message) {
                e.preventDefault();
                alert('Please fill in all required fields.');
            }
        });
    });
</script>
`;
%>
<%- include('layout', { body: body }) %>